{"name":"Tidy UI documentation site","description":"Tidy UI is a family of lightweight, modular React component library, providing essential building blocks for effortless application development. \n        The components are powered styled-components, features include css-in-js, typography, layouts, theming etc","short_name":"tidy-ui-docs","start_url":"/","display":"standalone","icons":[{"src":"icons/icon-48x48.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"48x48","type":"image/png"},{"src":"icons/icon-72x72.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"72x72","type":"image/png"},{"src":"icons/icon-96x96.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"96x96","type":"image/png"},{"src":"icons/icon-144x144.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"144x144","type":"image/png"},{"src":"icons/icon-192x192.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"192x192","type":"image/png"},{"src":"icons/icon-256x256.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"256x256","type":"image/png"},{"src":"icons/icon-384x384.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"384x384","type":"image/png"},{"src":"icons/icon-512x512.png?v=795bb67e0c4379f204fb21dde2433e26","sizes":"512x512","type":"image/png"}]}